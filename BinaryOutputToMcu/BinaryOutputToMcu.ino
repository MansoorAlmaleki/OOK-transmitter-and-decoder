unsigned long CurrentMicros = 0;
unsigned long Index = 0;
bool RunPreAmble = true;
bool RunPostAmble = false;
bool RunByteData = false;
bool EndTransmission = false;

void setup() {
  // put your setup code here, to run once:
  pinMode(53, OUTPUT);

}

void loop() {

  if(micros() - CurrentMicros >= 25000 && EndTransmission == false){
    CurrentMicros = micros();

    if(RunPreAmble){
       if(Index > 7){
        RunPreAmble = false;
        RunByteData = true;
        Index = 0;
        digitalWrite(53, 0);

      }else{
        digitalWrite(53, BytePreambleArray[Index]);
      }
    }

    if(RunByteData){
      if(Index > 1023){
        RunByteData = false;
        RunPostAmble = true;
        Index = 0;
        digitalWrite(53, 0);
      }else{
        digitalWrite(53, ByteArray[Index]);
      }

    }

    if(RunPostAmble){
      if(Index > 7){
        EndTransmission = true;
        digitalWrite(53, 0);
      }else{
        digitalWrite(53, BytePostambleArray[Index]);
      }

    }
    Index++;
  }


}
